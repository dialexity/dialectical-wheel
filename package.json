{
  "name": "dialectical-wheel",
  "version": "1.2.1",
  "type": "module",
  "description": "React components for interactive dialectical wheel visualization",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/stories",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "dialectical",
    "wheel",
    "visualization",
    "dialectics",
    "philosophy",
    "thesis",
    "antithesis",
    "component"
  ],
  "author": "Evaldas Taroza <evaldas@dialexity.com>",
  "contributors": [
    "Justin Tan"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dialexity/dialectical-wheel.git"
  },
  "homepage": "https://github.com/dialexity/dialectical-wheel#readme",
  "bugs": {
    "url": "https://github.com/dialexity/dialectical-wheel/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-onboarding": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-storybook": "^10.5.3",
    "jest": "^30.4.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "rollup": "^4.62.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.5.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
